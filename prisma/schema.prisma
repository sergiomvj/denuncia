// Sexta do Empreendedor - Database Schema
// Prisma ORM Schema Definition

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// USUÁRIOS (ANUNCIANTES)
// ========================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String    @map("full_name")
  businessName  String    @map("business_name")
  whatsapp      String
  instagram     String?
  website       String?
  city          String
  state         String
  country       String    @default("United States")
  profileImage  String?   @map("profile_image")
  status        UserStatus @default(ACTIVE)
  isVip         Boolean   @default(false) @map("is_vip")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  ads           Ad[]
  payments      Payment[]
  notifications Notification[]

  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// ========================================
// CATEGORIAS
// ========================================

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  
  ads         Ad[]

  @@map("categories")
}

// ========================================
// ANÚNCIOS
// ========================================

model Ad {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  categoryId        String      @map("category_id")
  title             String
  shortDescription  String      @map("short_description")
  fullDescription   String      @map("full_description") @db.Text
  offerType         OfferType   @map("offer_type")
  price             Float?
  promotionText     String?     @map("promotion_text")
  city              String
  deliveryType      DeliveryType @map("delivery_type")
  externalLink      String?     @map("external_link")
  whatsappContact   String      @map("whatsapp_contact")
  status            AdStatus    @default(DRAFT)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  paymentAmount     Float?      @map("payment_amount")
  paymentDate       DateTime?   @map("payment_date")
  scheduledDate     DateTime?   @map("scheduled_date")
  publishedAt       DateTime?   @map("published_at")
  expiresAt         DateTime?   @map("expires_at")
  viewsCount        Int         @default(0) @map("views_count")
  clicksCount       Int         @default(0) @map("clicks_count")
  isFeatured        Boolean     @default(false) @map("is_featured")
  rejectionReason   String?     @map("rejection_reason")
  adminNotes        String?     @map("admin_notes") @db.Text
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user              User        @relation(fields: [userId], references: [id])
  category          Category    @relation(fields: [categoryId], references: [id])
  images            AdImage[]
  videos            AdVideo[]
  payments          Payment[]
  leads             Lead[]

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([scheduledDate])
  @@index([publishedAt])
  @@map("ads")
}

enum OfferType {
  PRODUCT
  SERVICE
}

enum DeliveryType {
  LOCAL
  ONLINE
  BOTH
}

enum AdStatus {
  DRAFT
  AWAITING_PAYMENT
  PAID
  UNDER_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

// ========================================
// MÍDIA DOS ANÚNCIOS
// ========================================

model AdImage {
  id         String   @id @default(uuid())
  adId       String   @map("ad_id")
  imageUrl   String   @map("image_url")
  order      Int      @default(0)
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  ad         Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@map("ad_images")
}

model AdVideo {
  id         String   @id @default(uuid())
  adId       String   @map("ad_id")
  videoUrl   String   @map("video_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  ad         Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@map("ad_videos")
}

// ========================================
// PAGAMENTOS
// ========================================

model Payment {
  id              String         @id @default(uuid())
  adId            String         @map("ad_id")
  userId          String         @map("user_id")
  amount          Float
  paymentMethod   PaymentMethod  @map("payment_method")
  transactionId   String?        @map("transaction_id")
  status          PaymentStatusEnum
  paymentProofUrl String?        @map("payment_proof_url")
  confirmedBy     String?        @map("confirmed_by")
  confirmedAt     DateTime?      @map("confirmed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  ad              Ad             @relation(fields: [adId], references: [id])
  user            User           @relation(fields: [userId], references: [id])

  @@index([adId])
  @@index([status])
  @@map("payments")
}

enum PaymentMethod {
  ZELLE
  STRIPE
  PAYPAL
}

enum PaymentStatusEnum {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

// ========================================
// LEADS (INTERESSE)
// ========================================

model Lead {
  id          String    @id @default(uuid())
  adId        String    @map("ad_id")
  userName    String?   @map("user_name")
  userEmail   String?   @map("user_email")
  userPhone   String?   @map("user_phone")
  source      LeadSource
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  ad          Ad        @relation(fields: [adId], references: [id])

  @@index([adId])
  @@map("leads")
}

enum LeadSource {
  WHATSAPP_CLICK
  WEBSITE_CLICK
  INTEREST_BUTTON
  INSTAGRAM_CLICK
}

// ========================================
// ADMINISTRAÇÃO
// ========================================

model AdminUser {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  fullName     String      @map("full_name")
  role         AdminRole
  permissions  Json?
  lastLogin    DateTime?   @map("last_login")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  actions      AdminAction[]

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  MODERATOR
  FINANCIAL
}

model AdminAction {
  id          String   @id @default(uuid())
  adminId     String   @map("admin_id")
  actionType  String   @map("action_type")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  admin       AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
  @@map("admin_actions")
}

// ========================================
// CUPONS
// ========================================

model Coupon {
  id            String      @id @default(uuid())
  code          String      @unique
  discountType  DiscountType @map("discount_type")
  discountValue Float       @map("discount_value")
  validFrom     DateTime    @map("valid_from")
  validUntil    DateTime    @map("valid_until")
  maxUses       Int         @map("max_uses")
  timesUsed     Int         @default(0) @map("times_used")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE
}

// ========================================
// NOTIFICAÇÕES
// ========================================

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  subject   String
  message   String           @db.Text
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?        @map("sent_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

enum NotificationType {
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ========================================
// CONFIGURAÇÕES
// ========================================

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
