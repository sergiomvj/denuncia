// SEXTOU.biz - Database Schema (PostgreSQL)
// Prisma ORM Schema Definition

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// USUÁRIOS (ANUNCIANTES)
// ========================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  businessName String   @map("business_name")
  whatsapp     String
  instagram    String?
  website      String?
  city         String
  state        String
  country      String   @default("United States")
  profileImage String?  @map("profile_image")
  status       String   @default("ACTIVE")
  isVip        Boolean  @default(false) @map("is_vip")
  isAdmin      Boolean  @default(false) @map("is_admin")
  balance      Float    @default(0)
  affiliateId  String?  @map("affiliate_id")
  zelleCode    String?  @map("zelle_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ads                 Ad[]
  payments            Payment[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  toolExecutions      ToolExecution[]
  toolkitLeads        ToolkitLead[]
  toolkitQuotes       ToolkitQuote[]
  toolkitInvoices     ToolkitInvoice[]
  toolkitProjects     ToolkitProject[]
  toolkitTasks        ToolkitTask[]
  toolkitDirectoryEntries ToolkitDirectoryEntry[]

  affiliate   User?                @relation("UserAffiliates", fields: [affiliateId], references: [id])
  affiliates  User[]               @relation("UserAffiliates")
  territories AffiliateTerritory[]

  @@map("users")
}

// ========================================
// TERRITÓRIOS DE AFILIADOS
// ========================================

model MasterTerritory {
  id        String   @id @default(uuid())
  city      String
  state     String
  country   String   @default("United States")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  affiliates AffiliateTerritory[]

  @@unique([city, state])
  @@map("master_territories")
}

model AffiliateTerritory {
  id          String   @id @default(uuid())
  affiliateId String   @map("affiliate_id")
  territoryId String   @map("territory_id")
  createdAt   DateTime @default(now()) @map("created_at")

  affiliate User            @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  territory MasterTerritory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([affiliateId, territoryId])
  @@index([affiliateId])
  @@index([territoryId])
  @@map("affiliate_territories")
}

// ========================================
// CATEGORIAS
// ========================================

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true) @map("is_active")

  ads Ad[]

  @@map("categories")
}

// ========================================
// ANÚNCIOS
// ========================================

model Ad {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  categoryId       String    @map("category_id")
  title            String
  shortDescription String    @map("short_description")
  fullDescription  String    @map("full_description")
  offerType        String    @default("PRODUCT") @map("offer_type")
  price            Float?
  promotionText    String?   @map("promotion_text")
  city             String
  state            String?
  latitude         Float?
  longitude        Float?
  deliveryType     String    @default("LOCAL") @map("delivery_type")
  externalLink     String?   @map("external_link")
  whatsappContact  String    @map("whatsapp_contact")
  status           String    @default("DRAFT")
  paymentStatus    String    @default("PENDING") @map("payment_status")
  paymentAmount    Float?    @map("payment_amount")
  paymentDate      DateTime? @map("payment_date")
  scheduledDate    DateTime? @map("scheduled_date")
  publishedAt      DateTime? @map("published_at")
  expiresAt        DateTime? @map("expires_at")
  viewsCount       Int       @default(0) @map("views_count")
  clicksCount      Int       @default(0) @map("clicks_count")
  imageOrientation String    @default("VERTICAL") @map("image_orientation")
  isFeatured       Boolean   @default(false) @map("is_featured")
  rejectionReason  String?   @map("rejection_reason")
  adminNotes       String?   @map("admin_notes")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  images   AdImage[]
  videos   AdVideo[]
  payments Payment[]
  leads    Lead[]

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@map("ads")
}

// ========================================
// MÍDIA DOS ANÚNCIOS
// ========================================

model AdImage {
  id         String   @id @default(uuid())
  adId       String   @map("ad_id")
  imageUrl   String   @map("image_url")
  order      Int      @default(0)
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@map("ad_images")
}

model AdVideo {
  id         String   @id @default(uuid())
  adId       String   @map("ad_id")
  videoUrl   String   @map("video_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@map("ad_videos")
}

// ========================================
// PAGAMENTOS
// ========================================

model Payment {
  id              String    @id @default(uuid())
  adId            String    @map("ad_id")
  userId          String    @map("user_id")
  amount          Float
  paymentMethod   String    @default("ZELLE") @map("payment_method")
  transactionId   String?   @map("transaction_id")
  transactionDate DateTime? @map("transaction_date")
  status          String    @default("PENDING")
  paymentProofUrl String?   @map("payment_proof_url")
  confirmedBy     String?   @map("confirmed_by")
  confirmedAt     DateTime? @map("confirmed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  ad   Ad   @relation(fields: [adId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([adId])
  @@index([status])
  @@map("payments")
}

// ========================================
// LEADS (INTERESSE)
// ========================================

model Lead {
  id        String   @id @default(uuid())
  adId      String   @map("ad_id")
  userName  String?  @map("user_name")
  userEmail String?  @map("user_email")
  userPhone String?  @map("user_phone")
  source    String   @default("WEBSITE_CLICK")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  ad Ad @relation(fields: [adId], references: [id])

  @@index([adId])
  @@map("leads")
}

// ========================================
// ADMINISTRAÇÃO
// ========================================

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         String    @default("MODERATOR")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  actions AdminAction[]

  @@map("admin_users")
}

model AdminAction {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  actionType String   @map("action_type")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  details    String?  @map("details")
  createdAt  DateTime @default(now()) @map("created_at")

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
  @@map("admin_actions")
}

// ========================================
// CUPONS
// ========================================

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  discountType  String   @default("PERCENTAGE") @map("discount_type")
  discountValue Float    @map("discount_value")
  validFrom     DateTime @map("valid_from")
  validUntil    DateTime @map("valid_until")
  maxUses       Int      @map("max_uses")
  timesUsed     Int      @default(0) @map("times_used")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("coupons")
}

// ========================================
// NOTIFICAÇÕES
// ========================================

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String    @default("IN_APP")
  subject   String
  message   String
  status    String    @default("PENDING")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ========================================
// CONFIGURAÇÕES
// ========================================

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ========================================
// VÍDEOS DA PLATAFORMA
// ========================================

model Video {
  id          String   @id @default(uuid())
  title       String
  youtubeUrl  String   @map("youtube_url")
  description String?
  isFeatured  Boolean  @default(false) @map("is_featured")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("videos")
}

model ToolExecution {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  toolSlug     String   @map("tool_slug")
  inputJson    Json?    @map("input_json")
  outputJson   Json?    @map("output_json")
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([toolSlug])
  @@map("tool_executions")
}

model ToolkitLead {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  companyName    String?  @map("company_name")
  email          String?
  phone          String?
  source         String   @default("MANUAL")
  status         String   @default("NEW")
  estimatedValue Float?   @map("estimated_value")
  notes          String?
  tags           String[] @default([])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes   ToolkitQuote[]
  invoices ToolkitInvoice[]

  @@index([userId, status])
  @@index([createdAt])
  @@map("toolkit_leads")
}

model ToolkitQuote {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  leadId         String?  @map("lead_id")
  quoteNumber    String   @unique @map("quote_number")
  status         String   @default("DRAFT")
  title          String
  clientName     String   @map("client_name")
  clientCompany  String?  @map("client_company")
  clientEmail    String?  @map("client_email")
  clientPhone    String?  @map("client_phone")
  currency       String   @default("USD")
  issueDate      DateTime @map("issue_date")
  validUntil     DateTime? @map("valid_until")
  notes          String?
  lineItemsJson  Json     @map("line_items_json")
  subtotal       Float
  taxPercent     Float    @default(0) @map("tax_percent")
  taxAmount      Float    @default(0) @map("tax_amount")
  discountAmount Float    @default(0) @map("discount_amount")
  total          Float
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead     ToolkitLead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoices ToolkitInvoice[]

  @@index([userId, status])
  @@index([leadId])
  @@map("toolkit_quotes")
}

model ToolkitInvoice {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  leadId          String?   @map("lead_id")
  quoteId         String?   @map("quote_id")
  invoiceNumber   String    @unique @map("invoice_number")
  status          String    @default("DRAFT")
  title           String
  clientName      String    @map("client_name")
  clientCompany   String?   @map("client_company")
  clientEmail     String?   @map("client_email")
  clientPhone     String?   @map("client_phone")
  currency        String    @default("USD")
  issueDate       DateTime  @map("issue_date")
  dueDate         DateTime? @map("due_date")
  notes           String?
  lineItemsJson   Json      @map("line_items_json")
  subtotal        Float
  taxPercent      Float     @default(0) @map("tax_percent")
  taxAmount       Float     @default(0) @map("tax_amount")
  discountAmount  Float     @default(0) @map("discount_amount")
  total           Float
  emailSubject    String?   @map("email_subject")
  emailMessage    String?   @map("email_message")
  lastEmailSentAt DateTime? @map("last_email_sent_at")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead  ToolkitLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quote ToolkitQuote? @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([leadId])
  @@index([quoteId])
  @@map("toolkit_invoices")
}

model ToolkitProject {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  status      String   @default("PLANNING")
  priority    String   @default("MEDIUM")
  dueDate     DateTime? @map("due_date")
  progress    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks ToolkitTask[]

  @@index([userId, status])
  @@map("toolkit_projects")
}

model ToolkitTask {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  projectId    String    @map("project_id")
  title        String
  description  String?
  status       String    @default("TODO")
  priority     String    @default("MEDIUM")
  assigneeName String?   @map("assignee_name")
  dueDate      DateTime? @map("due_date")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project ToolkitProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([projectId, status])
  @@map("toolkit_tasks")
}

model ToolkitDirectoryEntry {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  businessName     String   @map("business_name")
  ownerName        String   @map("owner_name")
  category         String
  city             String
  state            String
  phone            String?
  whatsapp         String?
  email            String?
  instagram        String?
  website          String?
  shortDescription String   @map("short_description")
  servicesSummary  String?  @map("services_summary")
  badgeLabel       String?  @map("badge_label")
  status           String   @default("PENDING")
  isPublic         Boolean  @default(true) @map("is_public")
  adminNotes       String?  @map("admin_notes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, category])
  @@map("toolkit_directory_entries")
}
