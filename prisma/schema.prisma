// SEXTOU.biz - Database Schema (PostgreSQL)
// Prisma ORM Schema Definition

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// USUÁRIOS (ANUNCIANTES)
// ========================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  businessName String   @map("business_name")
  whatsapp     String
  instagram    String?
  website      String?
  city         String
  state        String
  country      String   @default("United States")
  profileImage String?  @map("profile_image")
  status       String   @default("ACTIVE")
  isVip        Boolean  @default(false) @map("is_vip")
  isAdmin      Boolean  @default(false) @map("is_admin")
  hasActiveAds Boolean  @default(false) @map("has_active_ads")
  isPremium    Boolean  @default(false) @map("is_premium")
  premiumPlanSlug  String?   @map("premium_plan_slug")
  premiumSince     DateTime? @map("premium_since")
  premiumExpiresAt DateTime? @map("premium_expires_at")
  balance      Float    @default(0)
  affiliateId  String?  @map("affiliate_id")
  zelleCode    String?  @map("zelle_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ads                 Ad[]
  payments            Payment[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  toolExecutions      ToolExecution[]
  toolkitLeads        ToolkitLead[]
  toolkitQuotes       ToolkitQuote[]
  toolkitInvoices     ToolkitInvoice[]
  toolkitProjects     ToolkitProject[]
  toolkitTasks        ToolkitTask[]
  toolkitDirectoryEntries ToolkitDirectoryEntry[]
  sextouToolsProGenerations SextouToolsProGeneration[]
  sextouToolsProUsageEvents SextouToolsProUsageEvent[]
  zapConnections ZapConnection[]
  zapGroups      ZapGroup[]
  zapExtractions ZapGroupExtraction[]
  contacts       Contact[]
  zapLeads       ZapLead[]
  leadEvents     LeadEvent[]
  zapMessages    ZapMessage[]
  messageTemplates MessageTemplate[]
  consentLogs    ConsentLog[]

  affiliate   User?                @relation("UserAffiliates", fields: [affiliateId], references: [id])
  affiliates  User[]               @relation("UserAffiliates")
  territories AffiliateTerritory[]

  @@map("users")
}

// ========================================
// TERRITÓRIOS DE AFILIADOS
// ========================================

model MasterTerritory {
  id        String   @id @default(uuid())
  city      String
  state     String
  country   String   @default("United States")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  affiliates AffiliateTerritory[]

  @@unique([city, state])
  @@map("master_territories")
}

model AffiliateTerritory {
  id          String   @id @default(uuid())
  affiliateId String   @map("affiliate_id")
  territoryId String   @map("territory_id")
  createdAt   DateTime @default(now()) @map("created_at")

  affiliate User            @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  territory MasterTerritory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([affiliateId, territoryId])
  @@index([affiliateId])
  @@index([territoryId])
  @@map("affiliate_territories")
}

// ========================================
// CATEGORIAS
// ========================================

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true) @map("is_active")

  ads Ad[]

  @@map("categories")
}

// ========================================
// ANÚNCIOS
// ========================================

model Ad {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  categoryId       String    @map("category_id")
  title            String
  shortDescription String    @map("short_description")
  fullDescription  String    @map("full_description")
  offerType        String    @default("PRODUCT") @map("offer_type")
  price            Float?
  promotionText    String?   @map("promotion_text")
  city             String
  state            String?
  latitude         Float?
  longitude        Float?
  deliveryType     String    @default("LOCAL") @map("delivery_type")
  externalLink     String?   @map("external_link")
  whatsappContact  String    @map("whatsapp_contact")
  status           String    @default("DRAFT")
  paymentStatus    String    @default("PENDING") @map("payment_status")
  paymentAmount    Float?    @map("payment_amount")
  paymentDate      DateTime? @map("payment_date")
  scheduledDate    DateTime? @map("scheduled_date")
  publishedAt      DateTime? @map("published_at")
  expiresAt        DateTime? @map("expires_at")
  viewsCount       Int       @default(0) @map("views_count")
  clicksCount      Int       @default(0) @map("clicks_count")
  imageOrientation String    @default("VERTICAL") @map("image_orientation")
  isFeatured       Boolean   @default(false) @map("is_featured")
  rejectionReason  String?   @map("rejection_reason")
  adminNotes       String?   @map("admin_notes")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  images   AdImage[]
  videos   AdVideo[]
  payments Payment[]
  leads    Lead[]

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@map("ads")
}

// ========================================
// MÍDIA DOS ANÚNCIOS
// ========================================

model AdImage {
  id         String   @id @default(uuid())
  adId       String   @map("ad_id")
  imageUrl   String   @map("image_url")
  order      Int      @default(0)
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@map("ad_images")
}

model AdVideo {
  id         String   @id @default(uuid())
  adId       String   @map("ad_id")
  videoUrl   String   @map("video_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@map("ad_videos")
}

// ========================================
// PAGAMENTOS
// ========================================

model Payment {
  id              String    @id @default(uuid())
  adId            String    @map("ad_id")
  userId          String    @map("user_id")
  amount          Float
  paymentMethod   String    @default("ZELLE") @map("payment_method")
  transactionId   String?   @map("transaction_id")
  transactionDate DateTime? @map("transaction_date")
  status          String    @default("PENDING")
  paymentProofUrl String?   @map("payment_proof_url")
  confirmedBy     String?   @map("confirmed_by")
  confirmedAt     DateTime? @map("confirmed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  ad   Ad   @relation(fields: [adId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([adId])
  @@index([status])
  @@map("payments")
}

// ========================================
// LEADS (INTERESSE)
// ========================================

model Lead {
  id        String   @id @default(uuid())
  adId      String   @map("ad_id")
  userName  String?  @map("user_name")
  userEmail String?  @map("user_email")
  userPhone String?  @map("user_phone")
  source    String   @default("WEBSITE_CLICK")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  ad Ad @relation(fields: [adId], references: [id])

  @@index([adId])
  @@map("leads")
}

// ========================================
// ADMINISTRAÇÃO
// ========================================

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         String    @default("MODERATOR")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  actions AdminAction[]

  @@map("admin_users")
}

model AdminAction {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  actionType String   @map("action_type")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  details    String?  @map("details")
  createdAt  DateTime @default(now()) @map("created_at")

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
  @@map("admin_actions")
}

// ========================================
// CUPONS
// ========================================

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  discountType  String   @default("PERCENTAGE") @map("discount_type")
  discountValue Float    @map("discount_value")
  validFrom     DateTime @map("valid_from")
  validUntil    DateTime @map("valid_until")
  maxUses       Int      @map("max_uses")
  timesUsed     Int      @default(0) @map("times_used")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("coupons")
}

// ========================================
// NOTIFICAÇÕES
// ========================================

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String    @default("IN_APP")
  subject   String
  message   String
  status    String    @default("PENDING")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ========================================
// CONFIGURAÇÕES
// ========================================

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ========================================
// VÍDEOS DA PLATAFORMA
// ========================================

model Video {
  id          String   @id @default(uuid())
  title       String
  youtubeUrl  String   @map("youtube_url")
  description String?
  isFeatured  Boolean  @default(false) @map("is_featured")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("videos")
}

model ToolExecution {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  toolSlug     String   @map("tool_slug")
  inputJson    Json?    @map("input_json")
  outputJson   Json?    @map("output_json")
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([toolSlug])
  @@map("tool_executions")
}

model ToolkitLead {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  companyName    String?  @map("company_name")
  email          String?
  phone          String?
  source         String   @default("MANUAL")
  status         String   @default("NEW")
  estimatedValue Float?   @map("estimated_value")
  notes          String?
  tags           String[] @default([])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes   ToolkitQuote[]
  invoices ToolkitInvoice[]

  @@index([userId, status])
  @@index([createdAt])
  @@map("toolkit_leads")
}

model ToolkitQuote {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  leadId         String?  @map("lead_id")
  quoteNumber    String   @unique @map("quote_number")
  status         String   @default("DRAFT")
  title          String
  clientName     String   @map("client_name")
  clientCompany  String?  @map("client_company")
  clientEmail    String?  @map("client_email")
  clientPhone    String?  @map("client_phone")
  currency       String   @default("USD")
  issueDate      DateTime @map("issue_date")
  validUntil     DateTime? @map("valid_until")
  notes          String?
  lineItemsJson  Json     @map("line_items_json")
  subtotal       Float
  taxPercent     Float    @default(0) @map("tax_percent")
  taxAmount      Float    @default(0) @map("tax_amount")
  discountAmount Float    @default(0) @map("discount_amount")
  total          Float
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead     ToolkitLead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoices ToolkitInvoice[]

  @@index([userId, status])
  @@index([leadId])
  @@map("toolkit_quotes")
}

model ToolkitInvoice {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  leadId          String?   @map("lead_id")
  quoteId         String?   @map("quote_id")
  invoiceNumber   String    @unique @map("invoice_number")
  status          String    @default("DRAFT")
  title           String
  clientName      String    @map("client_name")
  clientCompany   String?   @map("client_company")
  clientEmail     String?   @map("client_email")
  clientPhone     String?   @map("client_phone")
  currency        String    @default("USD")
  issueDate       DateTime  @map("issue_date")
  dueDate         DateTime? @map("due_date")
  notes           String?
  lineItemsJson   Json      @map("line_items_json")
  subtotal        Float
  taxPercent      Float     @default(0) @map("tax_percent")
  taxAmount       Float     @default(0) @map("tax_amount")
  discountAmount  Float     @default(0) @map("discount_amount")
  total           Float
  emailSubject    String?   @map("email_subject")
  emailMessage    String?   @map("email_message")
  lastEmailSentAt DateTime? @map("last_email_sent_at")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead  ToolkitLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quote ToolkitQuote? @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([leadId])
  @@index([quoteId])
  @@map("toolkit_invoices")
}

model ToolkitProject {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  status      String   @default("PLANNING")
  priority    String   @default("MEDIUM")
  dueDate     DateTime? @map("due_date")
  progress    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks ToolkitTask[]

  @@index([userId, status])
  @@map("toolkit_projects")
}

model ToolkitTask {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  projectId    String    @map("project_id")
  title        String
  description  String?
  status       String    @default("TODO")
  priority     String    @default("MEDIUM")
  assigneeName String?   @map("assignee_name")
  dueDate      DateTime? @map("due_date")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project ToolkitProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([projectId, status])
  @@map("toolkit_tasks")
}

model ToolkitDirectoryEntry {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  businessName     String   @map("business_name")
  ownerName        String   @map("owner_name")
  category         String
  city             String
  state            String
  phone            String?
  whatsapp         String?
  email            String?
  instagram        String?
  website          String?
  shortDescription String   @map("short_description")
  servicesSummary  String?  @map("services_summary")
  badgeLabel       String?  @map("badge_label")
  status           String   @default("PENDING")
  isPublic         Boolean  @default(true) @map("is_public")
  adminNotes       String?  @map("admin_notes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, category])
  @@map("toolkit_directory_entries")
}

model SextouToolsProGeneration {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  appId            String   @map("app_id")
  title            String
  inputData        Json     @map("input_data")
  outputData       Json     @map("output_data")
  outputText       String   @map("output_text")
  metadataJson     Json?    @map("metadata_json")
  language         String   @default("pt-BR")
  model            String
  promptVersion    String   @map("prompt_version")
  status           String   @default("ACTIVE")
  isFavorite       Boolean  @default(false) @map("is_favorite")
  sourceAction     String   @default("GENERATE") @map("source_action")
  sourceGenerationId String? @map("source_generation_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceGeneration  SextouToolsProGeneration? @relation("SextouToolsProGenerationLink", fields: [sourceGenerationId], references: [id], onDelete: SetNull)
  derivedGenerations SextouToolsProGeneration[] @relation("SextouToolsProGenerationLink")
  usageEvents       SextouToolsProUsageEvent[]

  @@index([userId, appId, createdAt])
  @@index([userId, status, createdAt])
  @@index([sourceGenerationId])
  @@map("sextou_tools_pro_generations")
}

model SextouToolsProPromptTemplate {
  id            String   @id @default(uuid())
  appId         String   @map("app_id")
  version       String
  model         String
  schemaName    String   @map("schema_name")
  systemPrompt  String   @map("system_prompt")
  schemaJson    Json     @map("schema_json")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([appId, version])
  @@index([appId, isActive])
  @@map("sextou_tools_pro_prompt_templates")
}

model SextouToolsProUsageEvent {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  appId         String   @map("app_id")
  generationId  String?  @map("generation_id")
  actionType    String   @map("action_type")
  createdAt     DateTime @default(now()) @map("created_at")

  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation SextouToolsProGeneration? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, appId, createdAt])
  @@index([generationId, actionType])
  @@map("sextou_tools_pro_usage_events")
}

// ========================================
// SEXTOU ZAPLEADS CRM (Premium)
// ========================================

model ZapConnection {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  mode               String    // 'web' or 'official'
  displayNumber      String?   @map("display_number")
  wabaPhoneId        String?   @map("waba_phone_id")
  sessionRef         String?   @map("session_ref")
  status             String    @default("disconnected")
  riskAcknowledgedAt DateTime? @map("risk_acknowledged_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups ZapGroup[]

  @@index([userId])
  @@map("zap_connections")
}

model ZapGroup {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  connectionId     String?   @map("connection_id")
  externalGroupId  String    @map("external_group_id")
  name             String?
  memberCount      Int?      @map("member_count")
  lastExtractedAt  DateTime? @map("last_extracted_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection  ZapConnection?        @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  extractions ZapGroupExtraction[]
  contacts    Contact[]

  @@index([userId])
  @@map("zap_groups")
}

model ZapGroupExtraction {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  groupId         String   @map("group_id")
  declaredPurpose String   @map("declared_purpose")
  limitApplied    Int?     @map("limit_applied")
  totalFound      Int?     @map("total_found")
  totalImported   Int?     @map("total_imported")
  totalSkipped    Int?     @map("total_skipped")
  createdAt       DateTime @default(now()) @map("created_at")

  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group ZapGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([groupId])
  @@map("zap_group_extractions")
}

model Contact {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  phoneE164     String   @map("phone_e164")
  displayName   String?  @map("display_name")
  email         String?
  company       String?
  notes         String?  @db.Text
  sourceType    String   @default("group") @map("source_type")
  sourceGroupId String?  @map("source_group_id")
  persona       String?
  tags          String[] @default([])
  isValid       Boolean  @default(true) @map("is_valid")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceGroup ZapGroup?     @relation(fields: [sourceGroupId], references: [id], onDelete: SetNull)
  zapLeads    ZapLead[]
  consentLogs ConsentLog[]

  @@unique([userId, phoneE164])
  @@index([userId, sourceGroupId])
  @@map("contacts")
}

model ZapLead {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  contactId          String    @map("contact_id")
  status             String    @default("frio")
  heatScore          Int       @default(0) @map("heat_score")
  ownerId            String?   @map("owner_id")
  estimatedValue     Float?    @map("estimated_value")
  nextFollowupAt     DateTime? @map("next_followup_at")
  firstContactedAt   DateTime? @map("first_contacted_at")
  becameHotAt        DateTime? @map("became_hot_at")
  lastInteractionAt  DateTime? @map("last_interaction_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact       Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  statusHistory LeadStatusHistory[]
  events        LeadEvent[]
  messages      ZapMessage[]

  @@index([userId, status])
  @@index([userId, heatScore(sort: Desc)])
  @@index([userId, nextFollowupAt])
  @@map("zap_leads")
}

model LeadStatusHistory {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  reason     String?
  changedBy  String?  @map("changed_by")
  createdAt  DateTime @default(now()) @map("created_at")

  lead ZapLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_status_history")
}

model LeadEvent {
  id             String   @id @default(uuid())
  leadId         String   @map("lead_id")
  userId         String   @map("user_id")
  eventType      String   @map("event_type")
  payload        Json?
  detectedIntent String?  @map("detected_intent")
  sentiment      String?
  createdAt      DateTime @default(now()) @map("created_at")

  lead ZapLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("lead_events")
}

model ZapMessage {
  id                String   @id @default(uuid())
  leadId            String   @map("lead_id")
  userId            String   @map("user_id")
  direction         String   // 'out' or 'in'
  channel           String   @default("whatsapp")
  body              String?
  templateId        String?  @map("template_id")
  aiGenerated       Boolean  @default(false) @map("ai_generated")
  status            String?
  externalMessageId String?  @map("external_message_id")
  createdAt         DateTime @default(now()) @map("created_at")

  lead ZapLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([userId])
  @@map("zap_messages")
}

model MessageTemplate {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  name       String
  objective  String?
  tone       String?
  language   String   @default("pt-BR")
  body       String
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("message_templates")
}

model ConsentLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  contactId String?  @map("contact_id")
  action    String
  basis     String?
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([contactId, action])
  @@index([userId])
  @@map("consent_log")
}

